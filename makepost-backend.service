[Unit]
Description=MakePost Flask Backend
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/linkedin-generator/backend
EnvironmentFile=/var/www/linkedin-generator/backend/.env
ExecStart=/usr/local/bin/gunicorn --workers 3 --bind 127.0.0.1:5000 --timeout 120 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
